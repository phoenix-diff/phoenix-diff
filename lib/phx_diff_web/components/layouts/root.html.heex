<!DOCTYPE html>
<html lang="en" class="min-h-screen">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title prefix="PhoenixDiff · ">
      {assigns[:page_title] || ""}
    </.live_title>
    <meta name="description" content="See the changes needed to upgrade your Phoenix application" />
    <meta name="keywords" content="Elixir,Phoenix,PhoenixFramework,Upgrade,Diff,PhoenixDiff" />
    <meta name="author" content="Navin Peiris @navinpeiris" />

    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />

    <link rel="stylesheet" href="https://fonts.googleapis.com/css?family=Open+Sans:300,400,700" />

    <.honeybadger_error_tracking honeybadger={@honeybadger} />

    <link rel="stylesheet" href={~p"/assets/app.css"} />
    <script defer phx-track-static src={~p"/assets/app.js"}>
    </script>
  </head>

  <body class="min-h-screen flex flex-col">
    <nav role="navigation">
      <div class="p-4 flex text-brand justify-between items-center">
        <a class="text-2xl font-bold" href="/">PhoenixDiff</a>

        <button
          class="sm:hidden"
          phx-click={
            JS.toggle(
              to: "#mobile-menu",
              display: "flex",
              in: {"transition-all ease-out duration-200", "opacity-0 -translate-y-2", "opacity-100 translate-y-0"},
              out: {"transition-all ease-in duration-150", "opacity-100 translate-y-0", "opacity-0 -translate-y-2"}
            )
            |> JS.toggle(to: "#nav-icon-open")
            |> JS.toggle(to: "#nav-icon-close")
          }
          aria-label="Toggle menu"
        >
          <span id="nav-icon-open"><.icon name="hero-bars-3" class="w-6 h-6" /></span>
          <span id="nav-icon-close" class="hidden"><.icon name="hero-x-mark" class="w-6 h-6" /></span>
        </button>

        <ul class="hidden sm:flex gap-1 items-center">
          <li>
            <.link navigate={~p"/compare"} class={["rounded-md px-3 py-1.5 text-sm transition-colors duration-150 hover:bg-brand/10", String.starts_with?(@current_path, "/compare") && "bg-brand/15 font-medium"]}>Compare</.link>
          </li>
          <li>
            <.link navigate={~p"/browse"} class={["rounded-md px-3 py-1.5 text-sm transition-colors duration-150 hover:bg-brand/10", String.starts_with?(@current_path, "/browse") && "bg-brand/15 font-medium"]}>Browse</.link>
          </li>
          <li>
            <a href="https://github.com/navinpeiris/phoenix-diff" target="_blank" class="flex items-center rounded-md p-1.5 transition-colors duration-150 hover:bg-brand/10">
              <.icon name="fa-github-brand" class="w-5 h-5" />
            </a>
          </li>
        </ul>
      </div>

      <div id="mobile-menu" class="hidden sm:hidden border-t border-brand/20 text-brand">
        <ul class="w-full">
          <li>
            <.link navigate={~p"/compare"} class="block text-right px-4 py-3 hover:bg-brand/10">
              Compare
            </.link>
          </li>
          <li>
            <.link navigate={~p"/browse"} class="block text-right px-4 py-3 hover:bg-brand/10">
              Browse
            </.link>
          </li>
          <li>
            <a href="https://github.com/navinpeiris/phoenix-diff" target="_blank" class="flex justify-end items-center gap-2 px-4 py-3 hover:bg-brand/10">
              GitHub <.icon name="fa-github-brand" class="w-4 h-4 align-[-.125rem]" />
            </a>
          </li>
        </ul>
      </div>
    </nav>

    <main role="main" class="flex-1">
      {@inner_content}
    </main>

    <footer class="bg-neutral text-neutral-content">
      <div class="container mx-auto px-3 py-4 text-center text-sm">
        To all alchemists with <.icon name="fa-heart-solid" class="w-4 h-4 align-[-.125rem]" /> by
        <a class="underline" href="https://github.com/navinpeiris" target="_blank">
          Navin Peiris
        </a>
        &amp;
        <a class="underline" href="https://github.com/aaronrenner" target="_blank">
          Aaron Renner
        </a>
      </div>
    </footer>

    <%= if @analytics.enabled? do %>
      <.google_analytics tracking_id={@analytics.ga_tracking_id} />
    <% end %>
  </body>
</html>
